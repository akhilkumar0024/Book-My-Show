pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner' 
        DOCKER_IMAGE_NAME = 'akhilkumar119/bms'
        EKS_CLUSTER_NAME = 'bookmyshow-eks'
        AWS_REGION = 'ap-south-1'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                // Updated to 'main' branch as requested
                git branch: 'main', credentialsId: 'github-cred', url: 'https://github.com/akhilkumar0024/Book-My-Show.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh ''' 
                    $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=BMS \
                        -Dsonar.projectKey=BMS
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    // Updated to match your ID: 'SonarQube-token'
                    waitForQualityGate abortPipeline: false, credentialsId: 'SonarQube-token'
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs . > trivyfs.txt'
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                        sh ''' 
                        echo "Building Docker image version ${BUILD_NUMBER}..."
                        docker build --no-cache -t $DOCKER_IMAGE_NAME:${BUILD_NUMBER} -f bookmyshow-app/Dockerfile bookmyshow-app

                        echo "Tagging as latest for convenience..."
                        docker tag $DOCKER_IMAGE_NAME:${BUILD_NUMBER} $DOCKER_IMAGE_NAME:latest

                        echo "Pushing both tags..."
                        docker push $DOCKER_IMAGE_NAME:${BUILD_NUMBER}
                        docker push $DOCKER_IMAGE_NAME:latest
                        '''
                    }
                }
            }
        }

        stage('Deploy to EKS Cluster') {
            steps {
                script {
                    sh '''
                    aws eks update-kubeconfig --name $EKS_CLUSTER_NAME --region $AWS_REGION

                    echo "Updating deployment.yml to use version ${BUILD_NUMBER}..."
                    # This specific sed command finds the image line and swaps it for the unique build tag
                    sed -i "s|image:.*|image: $DOCKER_IMAGE_NAME:${BUILD_NUMBER}|g" deployment.yml

                    kubectl apply -f deployment.yml
                    kubectl apply -f service.yml
                    '''
                }
            }
        }
    }

    post {
        always {
            emailext attachLog: true,
                subject: "Build ${currentBuild.fullDisplayName} - ${currentBuild.result}",
                body: "Check the attached Trivy report for security vulnerabilities.",
                to: 'akhilkumar0024@gmail.com',
                attachmentsPattern: 'trivyfs.txt'
        }
    }
}